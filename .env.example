# Database — Supabase PostgreSQL
# Pooled connection (cho runtime, qua Supabase connection pooler)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres"
# Direct connection (cho prisma db push / migrate)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# URL ứng dụng
APP_URL="http://localhost:3000"

# Tài khoản admin
ADMIN_EMAIL="admin@local.test"
# bcrypt hash của mật khẩu admin. Sinh bằng: npx tsx scripts/hash-password.ts
ADMIN_PASSWORD_HASH=""

# Ký session cookie (chuỗi ngẫu nhiên dài, >= 32 ký tự)
SESSION_SECRET="doi-thanh-chuoi-ngau-nhien-that-dai-o-day"

# Thư mục lưu upload local
UPLOAD_ROOT="./storage/uploads"

# Bí mật để hash IP (khác SESSION_SECRET)
IP_HASH_SECRET="doi-thanh-chuoi-ngau-nhien-khac-o-day"
